# Copy this file to .env and fill in real values before running the proxy.
# The proxy reads these via os.environ — it will refuse to start if they are missing.

# Duke Energy outage API — Base64-encoded "username:password" (Basic Auth)
DUKE_ENERGY_AUTH=Basic <your_base64_credential_here>

# PulsePoint payload decryption secret
PULSEPOINT_SECRET=<your_secret_here>

# Optional: set to 1 to enable verbose debug logging (never use in production)
# FLORIDAMAP_DEBUG=0
